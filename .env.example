# Environment configuration for the Crawmatic monorepo skeleton.
#
# Copy this file to `.env` (git-ignored) before running
# `docker compose up --build -d`. The placeholders below are safe for
# local development only — no real secrets are committed here.
#
# Every variable is drawn from specs/001-monorepo-skeleton/contracts/environment.md
# (the authoritative catalogue). `app_shared/config.py` (pydantic-settings)
# fails fast if a required variable is missing (FR-017).

# --- Database (api, scheduler, worker; scrapers later) ---
# Host must be pgbouncer:6432 — app services never talk to postgres:5432
# directly (FR-011).
DATABASE_URL=postgresql+psycopg://crawmatic:crawmatic@pgbouncer:6432/crawmatic
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2

# --- Migration job only (direct-to-Postgres, bypasses PgBouncer) ---
# App services (api/scheduler/worker) use DATABASE_URL above (pooler,
# pgbouncer:6432) and never set this. Only the one-shot migration job /
# Alembic env.py uses MIGRATION_DATABASE_URL, connecting directly to
# postgres:5432 — advisory locks and concurrent index builds are unsafe
# through the transaction pooler.
MIGRATION_DATABASE_URL=postgresql+psycopg://crawmatic:crawmatic@postgres:5432/crawmatic

# --- Redis (worker; others as needed) ---
REDIS_URL=redis://redis:6379/0

# --- Scrapyd pools & auth (worker; scrapers nodes) ---
# Comma-separated pools (FR-018); a single URL is still treated as a pool.
SCRAPYD_HTTP_URLS=http://scrapers:6800
SCRAPYD_BROWSER_URLS=http://scrapers-browser:6800
SCRAPYD_USERNAME=scrapyd
SCRAPYD_PASSWORD=change-me

# --- API surface ---
# API_PORT is the single canonical API-port variable: it is both the
# host-published port and (via compose `environment: PORT=${API_PORT}`)
# the container's uvicorn --port, so listen/publish/healthcheck ports
# never diverge (FR-017).
API_PORT=8000
API_PUBLIC_BASE_URL=https://api.example.com
INTERNAL_API_BASE_URL=http://api:8000

# --- Auth / JWT (api; required — fails fast if unset, SPEC-03 FR-024) ---
# Local-only placeholder — generate a real random secret per environment
# (e.g. `openssl rand -hex 32`) and never commit a real value.
JWT_SECRET=change-me-local-dev-secret-32-bytes-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Status cache TTL (api; SPEC-03 FR-022) ---
STATUS_CACHE_TTL_SECONDS=30

# --- Login rate limiting (api; SPEC-03 FR-007) ---
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- API-key last_used throttle (api; SPEC-03 FR-015) ---
API_KEY_LAST_USED_THROTTLE_SECONDS=60

# --- Auth DB role (api; optional but required to actually authenticate) ---
# A dedicated `crawmatic_auth` role with BYPASSRLS, used ONLY for
# pre-context credential lookups (user-by-email, api-key-by-prefix).
# Without it, get_auth_session() fails fast (SPEC-03 [analyze C1]) rather
# than silently returning 0 rows under FORCE RLS.
AUTH_DATABASE_URL=postgresql+psycopg://crawmatic_auth:crawmatic@pgbouncer:6432/crawmatic

# --- Argon2id tuning (api; optional — argon2-cffi recommended defaults
# apply when unset) ---
# ARGON2_TIME_COST=3
# ARGON2_MEMORY_COST=65536
# ARGON2_PARALLELISM=4

# --- Local infra bootstrap (compose only) ---
POSTGRES_USER=crawmatic
POSTGRES_PASSWORD=crawmatic
POSTGRES_DB=crawmatic
# Local only — deployed envs MUST use scram-sha-256 with a real userlist.
PGBOUNCER_AUTH_TYPE=trust
PGBOUNCER_POOL_MODE=transaction
# Dual-stack (IPv4+IPv6) bind for PgBouncer.
PGBOUNCER_LISTEN_ADDR=*
